@* =================================================================================================================
 * DOSYA ADI: Hesabim.cshtml (Profil Bilgilerim)
 * AMACI: Kayıtlı kullanıcıların kişisel bilgilerini (Ad, Soyad, Telefon, Adres) görüntülemesini 
 * ve şifre güncelleme dahil tüm hesap detaylarını asenkron/senkron olarak yönetmesini sağlar.
 * * KULLANILAN TEKNOLOJİLER VE KÜTÜPHANELER:
 * - Razor View Engine: 'Kullanicilar' modeli üzerinden mevcut kullanıcı verilerinin form alanlarına enjekte edilmesi.
 * - CSS3 (Modern Styling): Pastel tonlarda (#f7d3e0) degrade arka plan tasarımı ve 'box-shadow' ile derinlik kazandırılmış kart yapısı.
 * - Flexbox Architecture: Formun sayfa ortasında dikey ve yatayda tam hizalanmasını sağlayan 'account-page-wrapper' mimarisi.
 * - Bootstrap Grid: Ad ve Soyad gibi alanların yan yana düzenli durması için kullanılan 'row/col' yapısı.
 * * TASARIM VE FONKSİYONEL DETAYLAR:
 * 1. Veri Güvenliği: E-posta adresi 'readonly' (sadece okunabilir) yapılarak birincil kimlik bilgisinin değiştirilmesi engellenmiştir.
 * 2. Akıllı Şifre Güncelleme: 'YeniSifre' alanı boş bırakıldığında mevcut şifreyi koruyan, dolduğunda güncelleyen arka plan mantığına uygun tasarım.
 * 3. Görsel Geri Bildirim: Form elemanlarına odaklanıldığında (focus) ortaya çıkan mor (#a259ff) çerçeve ve gölge efektleri.
 * 4. UX Detayları: Teslimat adresi için kullanılan 'textarea' alanında 'resize: none' kullanılarak sayfa düzeninin bozulması önlenmiştir.
 ================================================================================================================= *@

@model ClothingStore.Models.Kullanicilar
@{
    ViewData["Title"] = "Hesabım";
}

<style>

    .account-page-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        background: #f7d3e0; 
        padding: 40px 20px;
        border-radius: 20px;
    }

    .account-box {
        background: white;
        padding: 40px;
        width: 100%;
        max-width: 450px;
        border-radius: 16px;
        border-top: 5px solid #c084fc;
        box-shadow: 0 6px 18px rgba(0,0,0,0.12);
    }

    .account-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 20px;
    }

    .account-box h2 {
        margin: 0;
        color: #a259ff;
        font-weight: 700;
        font-size: 24px;
    }

    /* Form Elemanları */
    .account-box .form-control {
        border-radius: 10px;
        border: 1px solid #eee;
        padding: 10px;
        font-size: 14px;
        margin-bottom: 15px;
        background: #fdfdfd;
        transition: 0.3s;
    }

        .account-box .form-control:focus {
            border-color: #a259ff;
            box-shadow: 0 0 0 0.2rem rgba(162, 89, 255, 0.1);
        }

    .account-box label {
        font-size: 12px;
        font-weight: 700;
        color: #a259ff;
        text-transform: uppercase;
        margin-bottom: 5px;
        display: block;
    }

    .account-menu {
        margin-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

        .account-menu button {
            padding: 14px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(to right, #a259ff, #d6a4ff);
            color: white;
            cursor: pointer;
            transition: 0.3s;
            font-weight: 600;
            text-align: center;
            width: 100%;
        }

            .account-menu button:hover {
                transform: scale(1.02);
                box-shadow: 0 4px 12px rgba(162, 89, 255, 0.3);
            }

    .password-section {
        background: #fff9fc;
        padding: 15px;
        border-radius: 12px;
        border: 1px dashed #f7b2d9;
        margin-top: 5px;
    }
</style>

<div class="account-page-wrapper">
    <div class="account-box">
        <form action="/Account/BilgiGuncelle" method="post">
            <input type="hidden" name="KullaniciId" value="@Model.KullaniciId" />

            <div class="account-header">
                <div>
                    <h2>Profil Bilgilerim</h2>
                    <p style="font-size: 12px; color: #999; margin: 0;">Hesap detaylarınızı buradan güncelleyebilirsiniz.</p>
                </div>
                <div style="font-size: 30px;">👤</div>
            </div>

            <div class="account-info mt-4">
                <div class="row">
                    <div class="col-6">
                        <label>Ad</label>
                        <input type="text" name="Ad" class="form-control" value="@Model.Ad" required>
                    </div>
                    <div class="col-6">
                        <label>Soyad</label>
                        <input type="text" name="Soyad" class="form-control" value="@Model.Soyad" required>
                    </div>
                </div>

                <label>E-Posta Adresi </label>
                <input type="email" class="form-control" value="@Model.Email" readonly style="background: #f5f5f5; color: #888; cursor: not-allowed;">

                <label>Telefon</label>
                <input type="text" name="Telefon" class="form-control" value="@Model.Telefon">

                <label>Teslimat Adresi</label>
                <textarea name="Adres" class="form-control" rows="2" style="resize: none;">@Model.Adres</textarea>

                <div class="password-section">
                    <label style="color: #ff4fa3;"><i class="fa-solid fa-lock me-1"></i> Şifreyi Güncelle</label>
                    <input type="password" name="YeniSifre" class="form-control" placeholder="Değiştirmek istemiyorsanız boş bırakın" style="margin-bottom: 0;">
                </div>
            </div>

            <div class="account-menu">
                <button type="submit">✨ BİLGİLERİ GÜNCELLE</button>
            </div>
        </form>
    </div>
</div>