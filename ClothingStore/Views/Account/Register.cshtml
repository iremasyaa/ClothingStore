@* =================================================================================================================
 * DOSYA ADI: Register.cshtml (Kullanıcı Kayıt Sayfası)
 * AMACI: Yeni kullanıcıların sisteme kayıt olmasını sağlayarak müşteri veritabanına dahil edilmesini yönetir. 
 * Kullanıcıyı yormayan, sade ve modern bir veri giriş arayüzü sunar.
 * * KULLANILAN TEKNOLOJİLER VE KÜTÜPHANELER:
 * - Razor View Engine: 'Kullanicilar' modeli üzerinden veri bağlama ve dinamik hata yönetimi (ViewBag.Hata).
 * - Bootstrap 5: Sayfa bileşenlerinin düzeni ve duyarlı (responsive) tasarım altyapısı.
 * - CSS3 (Advanced UI): 'linear-gradient' arka plan geçişleri ve etkileşimli form alanları (focus states).
 * - Font-Awesome 6: Görsel geri bildirim sağlayan ikonların entegrasyonu.
 * * TASARIM VE FONKSİYONEL DETAYLAR:
 * 1. Form Yapılandırması: Ad ve Soyad alanları 'name-row' sınıfı ile yan yana getirilerek form uzunluğu optimize edilmiştir.
 * 2. Veri Entegrasyonu: Form verileri AccountController içerisindeki 'Register' aksiyonuna HTTP POST ile iletilir.
 * 3. Kullanıcı Deneyimi: 'input:focus' durumlarında kullanılan yumuşak renk değişimleri ile aktif alan belirginleştirilmiştir.
 * 4. Navigasyon: Giriş sayfasına (Login) ve ana sayfaya (Home/Index) yönlendiren bağlantılarla sayfa akışı desteklenmiştir.
 * 5. Bağımsız Tasarım: 'Layout = null' kullanılarak sayfanın ana siteden izole, bağımsız bir modül olması sağlanmıştır.
 ================================================================================================================= *@

@model ClothingStore.Models.Kullanicilar
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Üye Ol - ClothingStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .register-page {
            min-height: 100vh;
            background: linear-gradient(to right, #ffe0ec, #ffc2d9);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .register-box {
            width: 380px;
            background: white;
            padding: 35px;
            border-radius: 20px;
            border-top: 6px solid #c084fc;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

            .register-box h2 {
                text-align: center;
                color: #a259ff;
                margin-bottom: 25px;
                font-weight: 800;
            }

            .register-box form {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

        .name-row {
            display: flex;
            gap: 12px;
        }

            .name-row input {
                width: 50%;
            }

        .register-box input {
            padding: 12px;
            border: 2px solid #f3f3f3;
            border-radius: 10px;
            outline: none;
            transition: 0.3s;
        }

            .register-box input:focus {
                border-color: #c084fc;
                background-color: #fdfaff;
            }

        .register-box button {
            background: linear-gradient(to right, #a259ff, #d6a4ff);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1rem;
            transition: 0.3s;
            margin-top: 10px;
        }

            .register-box button:hover {
                transform: scale(1.03);
                box-shadow: 0 5px 15px rgba(162, 89, 255, 0.3);
            }

        .login-links {
            margin-top: 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .login-links a {
                color: #7a00ff;
                text-decoration: none;
                font-size: 14px;
                font-weight: 600;
            }

                .login-links a:hover {
                    text-decoration: underline;
                    color: #a259ff;
                }

        .alert-custom {
            border-radius: 10px;
            font-size: 0.9rem;
            margin-bottom: 15px;
        }
    </style>
</head>
<body class="register-page">

    <div class="register-box">
        <h2>Üye Ol</h2>

        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger alert-custom">
                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Hata
            </div>
        }

        <form action="/Account/Register" method="post">
            <div class="name-row">
                <input type="text" name="Ad" placeholder="Ad" required>
                <input type="text" name="Soyad" placeholder="Soyad" required>
            </div>

            <input type="email" name="Email" placeholder="E-Posta Adresi" required>

            <input type="password" name="Sifre" placeholder="Şifre" required>

            <input type="text" name="Telefon" placeholder="Telefon (Opsiyonel)">

            <button type="submit">Ücretsiz Kayıt Ol</button>
        </form>

        <div class="login-links">
            <a href="/Account/Login">Zaten hesabın var mı? Giriş Yap</a>
            <a href="/Home/Index" class="text-muted" style="font-weight: 400; font-size: 12px;">
                <i class="fas fa-arrow-left me-1"></i> Mağazaya Dön
            </a>
        </div>
    </div>

</body>
</html>