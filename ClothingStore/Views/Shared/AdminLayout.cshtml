@* =================================================================================================================
 * DOSYA ADI: AdminLayout.cshtml (Yönetim Paneli Ana Şablonu)
 * AMACI: Yönetici panelindeki tüm sayfaların (Ürün, Sipariş, Üye yönetimi vb.) ortak iskeletini oluşturur. 
 * Sabit bir yan menü (Sidebar) ve dinamik içerik alanı (Content) ile sistem yönetimini standartlaştırır.
 * * KULLANILAN TEKNOLOJİLER VE KÜTÜPHANELER:
 * - Razor View Engine: '@RenderBody()' ile alt sayfaların yüklenmesi ve '@await RenderSectionAsync' ile script yönetimi.
 * - CSS3 (Modern Admin UI): 'fixed' konumlandırmalı sidebar, 'overflow-y: auto' ile bağımsız kaydırma ve neon pembe tema.
 * - Bootstrap 5: Grid yapısı (Content margin-left yönetimi) ve interaktif bileşen desteği.
 * - Font-Awesome 6: Yönetim kategorilerini temsil eden profesyonel ikon setleri.
 * * TASARIM VE FONKSİYONEL DETAYLAR:
 * 1. Sidebar Mimarisi: 250px genişliğinde sabitlenmiş (fixed), sağ kenarı neon pembe (#FF1493) hatla 
 * ayrılmış profesyonel navigasyon alanı.
 * 2. Etkileşimli Menü Tasarımı: '.nav-link:hover' durumunda uygulanan 'padding-left' ve arka plan rengi 
 * değişimi ile sağlanan dinamik derinlik algısı.
 * 3. Merkezi Renk Paleti: Arka planda tam siyah (#000) ve koyu gri (#0d0d0d) kullanımıyla verilerin 
 * okunabilirliğini artıran "High Contrast" yapısı.
 * 4. Kapsamlı Navigasyon: Dashboard'dan üye detaylarına kadar tüm CRUD ekranlarına tek tıkla erişim sağlayan 
 * hiyerarşik link yapısı.
 * 5. Çıkış Güvenliği: Menü sonunda konumlandırılan 'Güvenli Çıkış' butonu ile yönetici oturumunun 
 * sonlandırılmasına yönelik hızlı erişim.
 ================================================================================================================= *@

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yönetim Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #0d0d0d;
            color: #ffffff;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .sidebar {
            background-color: #000;
            height: 100vh;
            position: fixed;
            width: 250px;
            border-right: 2px solid #FF1493;
            z-index: 1000;
            overflow-y: auto;
        }

        .content {
            margin-left: 250px;
            padding: 30px;
            background-color: #0d0d0d;
            min-height: 100vh;
        }

        .nav-link {
            color: #eee !important;
            padding: 15px 20px;
            border-bottom: 1px solid #222;
            display: block;
            text-decoration: none;
            transition: 0.3s;
            font-size: 14px;
        }

            .nav-link i {
                width: 25px;
                color: #FF1493;
                text-align: center;
            }

            .nav-link:hover {
                background-color: #FF1493;
                color: white !important;
                padding-left: 30px;
            }

                .nav-link:hover i {
                    color: white;
                }

        .text-turuncu {
            color: #FF1493 !important;
        }

        .text-muted {
            color: #bbb !important;
        }

        .modal-content {
            border-radius: 15px;
        }

        .border-turuncu {
            border: 1px solid #FF1493 !important;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="text-center p-4">
            <h3 class="text-turuncu fw-bold">ADMİN</h3>
            <small class="text-muted border-bottom border-secondary pb-2 d-block">Kontrol Paneli</small>
        </div>
        <nav class="nav flex-column mt-2">
            <a class="nav-link" href="/Admin/Index"><i class="fa fa-tachometer-alt"></i> Dashboard</a>

            <a class="nav-link" href="/Admin/Urunler"><i class="fa fa-shirt"></i> Ürün Yönetimi</a>

            <a class="nav-link" href="/Admin/Markalar"><i class="fa fa-tags"></i> Marka Yönetimi</a>

            <a class="nav-link" href="/Admin/Kategoriler"><i class="fa fa-layer-group"></i> Kategori Yönetimi</a>
            <a class="nav-link" href="/Admin/Siparisler"><i class="fa fa-shopping-cart"></i> Sipariş Yönetimi</a>
            <a class="nav-link" href="/Admin/Yorumlar"><i class="fa fa-comments"></i> Yorum Denetimi</a>
            <a class="nav-link" href="/Admin/Uyeler"><i class="fa fa-users"></i> Üye Detayları</a>

            <div class="px-4 mt-5">
                <a class="btn btn-outline-danger w-100 btn-sm" href="/Account/Logout">
                    <i class="fa fa-sign-out-alt me-2"></i>Güvenli Çıkış
                </a>
            </div>
        </nav>
    </div>

    <div class="content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>