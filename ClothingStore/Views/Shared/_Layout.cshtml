@* =================================================================================================================
 * DOSYA ADI: _Layout.cshtml (Ana Şablon Dosyası)
 * AMACI: Uygulamanın tüm sayfalarında ortak olan üst menü (Header), navigasyon (Navbar) ve temel stil 
 * yapılandırmasını yönetir. Kullanıcı oturumuna bağlı olarak dinamik içerik sunan merkezi şablondur.
 * * KULLANILAN TEKNOLOJİLER VE KÜTÜPHANELER:
 * - ASP.NET Core Session: Kullanıcı adı, ID'si ve sepet miktarının sunucu taraflı takibi.
 * - Dependency Injection (@inject): 'IHttpContextAccessor' ile Razor seviyesinde oturum verilerine erişim.
 * - CSS3 Variables & Flexbox: Merkezi renk paleti yönetimi (--grad-main, --purple-main) ve duyarlı yerleşim planı.
 * - Bootstrap 5 & Font-Awesome 6: UI bileşenleri, dropdown menüler ve vektörel ikon setleri.
 * * TASARIM VE FONKSİYONEL DETAYLAR:
 * 1. Dinamik Sepet Sayacı: Kullanıcı login olduğunda veritabanından sepet toplamını çeken ve 
 * performansı artırmak için bu bilgiyi 'Session'da saklayan akıllı sayaç mekanizması.
 * 2. Koşullu Kullanıcı Paneli: Giriş yapmış kullanıcılara 'Hesabım', 'Kombinlerim' ve 'Dolabım' gibi 
 * özel linkler sunarken; ziyaretçilere 'Üye Girişi' ve 'Kayıt Ol' seçeneklerini gösteren mantıksal yapı.
 * 3. Akıllı Arama Çubuğu: 'autocomplete="off"' özelliği ile temizlenmiş, tüm ürünlerde arama yapabilen global search modülü.
 * 4. Görsel Kimlik: Webkit-background-clip özelliği ile oluşturulan gradient (geçişli) logolar ve 
 * neon pembe vurgulu interaktif elemanlar.
 * 5. Mobil Uyumluluk: Medya sorguları (max-width: 768px) ile mobil cihazlarda arama çubuğunun alta kayması 
 * ve menülerin dikey dizilimi gibi duyarlı (responsive) optimizasyonlar.
 ================================================================================================================= *@

@using Microsoft.AspNetCore.Http
@using ClothingStore.Models
@inject IHttpContextAccessor HttpContextAccessor

@{
    int sepetAdet = 0;
    var kAdi = Context.Session.GetString("AdSoyad");
    var userId = Context.Session.GetInt32("KullaniciID");

    if (userId != null)
    {
        var sessionAdet = Context.Session.GetInt32("SepetAdet");
        if (sessionAdet != null) { sepetAdet = (int)sessionAdet; }
        else
        {
            using (var db = new ClothingStoreDbContext())
            {
                try
                {
                    sepetAdet = db.Sepets.Where(x => x.KullaniciId == userId).Sum(x => x.Adet ?? 0);
                    Context.Session.SetInt32("SepetAdet", sepetAdet);
                }
                catch { sepetAdet = 0; }
            }
        }
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clothing Store</title>

    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --purple-main: #a770ef;
            --pink-accent: #ff7eb3;
            --grad-main: linear-gradient(135deg, #ff7eb3 0%, #a770ef 100%);
            --soft-bg: #fff9fc;
            --deep-pink: #FF1493;
        }

        body {
            background-color: var(--soft-bg);
            font-family: 'Poppins', sans-serif;
            margin: 0;
        }

        .form-select:focus, .form-control:focus, select:focus, input:focus {
            border-color: var(--deep-pink) !important;
            box-shadow: 0 0 0 0.25rem rgba(255, 20, 147, 0.25) !important;
            outline: 0 !important;
        }

        ::selection {
            background: var(--pink-accent);
            color: white;
        }

        input[type="checkbox"], input[type="radio"] {
            accent-color: var(--deep-pink);
        }

        .main-header {
            background: white;
            padding: 15px 5%;
            border-bottom: 5px solid transparent;
            border-image: var(--grad-main) 1;
            box-shadow: 0 4px 15px rgba(167, 112, 239, 0.1);
            position: relative;
            z-index: 1000;
        }

        .logo {
            font-size: 30px;
            font-weight: 800;
            text-decoration: none;
            background: var(--grad-main);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .search-container {
            display: flex;
            width: 45%;
        }

        .search-box {
            border: 2px solid #eee;
            border-radius: 25px 0 0 25px !important;
            height: 45px;
            padding-left: 20px;
            outline: none;
        }

        .search-btn {
            background: var(--grad-main) !important;
            color: white !important;
            border: none !important;
            border-radius: 0 25px 25px 0 !important;
            height: 45px;
            width: 100px;
            font-weight: bold;
        }

        .login-area {
            cursor: pointer;
            text-align: right;
            line-height: 1.2;
            text-decoration: none !important;
        }

        .login-title {
            font-size: 12px;
            color: #888;
            display: block;
        }

        .login-name {
            font-weight: 800;
            color: var(--purple-main);
            font-size: 15px;
        }

        .dropdown-menu {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(167, 112, 239, 0.2) !important;
            padding: 10px;
            margin-top: 15px !important;
            z-index: 9999 !important;
        }

        .dropdown-item {
            border-radius: 10px;
            padding: 10px 15px;
            font-weight: 500;
            color: #555;
            transition: 0.2s;
        }

            .dropdown-item:hover {
                background-color: #fff0f5 !important;
                color: var(--purple-main) !important;
                transform: translateX(5px);
            }

            .dropdown-item i {
                color: var(--purple-main);
                margin-right: 10px;
                width: 20px;
                text-align: center;
            }

        .cart-container {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            border: 2px solid var(--purple-main);
            border-radius: 15px;
            color: var(--purple-main);
            font-weight: 700;
            position: relative;
            text-decoration: none;
        }

            .cart-container:hover {
                background: var(--grad-main);
                color: white !important;
                border-color: transparent;
            }

        .cart-badge {
            background: var(--pink-accent);
            color: white;
            border-radius: 50%;
            padding: 2px 7px;
            font-size: 11px;
            position: absolute;
            top: -10px;
            right: -10px;
        }

        .purple-nav {
            background: var(--grad-main);
            height: 50px;
            display: flex;
            align-items: center;
        }

        .nav-link-custom {
            color: white !important;
            font-weight: 600;
            padding: 0 25px;
            font-size: 13px;
            height: 50px;
            display: flex;
            align-items: center;
            text-transform: uppercase;
            text-decoration: none !important;
            transition: 0.3s;
        }

            .nav-link-custom:hover {
                background: rgba(255,255,255,0.2);
            }

        @@media (max-width: 768px) {
            .main-header {
                padding: 15px 3%; 
            }

            .logo {
                font-size: 22px;
            }

            .search-container {
                width: 100% !important; 
            }
         
            .cart-container span:not(.cart-badge) {
                display: none;
            }

            .cart-container {
                padding: 8px 12px;
            }

            .login-title {
                display: none;
            }

            .login-name {
                font-size: 13px;
            }

            .purple-nav {
                height: auto;
                padding: 10px 0;
            }

                .purple-nav .container-fluid {
                    flex-direction: column;
                    gap: 5px;
                }

                .purple-nav .d-flex {
                    justify-content: center;
                    flex-wrap: wrap;
                    gap: 5px;
                }

            .nav-link-custom {
                height: 35px;
                padding: 0 10px;
                font-size: 11px;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="main-header">
        <div class="d-flex align-items-center justify-content-between flex-wrap">

            <a href="/Home/Index" class="logo order-1"><i class="fa fa-tshirt me-2"></i>ClothingStore</a>

            <form action="/Urun/TumUrunler" method="get" class="search-container order-3 order-md-2 mt-3 mt-md-0" autocomplete="off">
                <input type="text" name="aranacakKelime" class="form-control search-box" placeholder="Ürün adı, beden veya renk ara..." autocomplete="off" required>
                <button type="submit" class="btn search-btn">ARA <i class="fa fa-search"></i></button>
            </form>

            <div class="d-flex align-items-center order-2 order-md-3" style="gap: 15px;">
                <div class="dropdown">
                    <div class="login-area dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (string.IsNullOrEmpty(kAdi))
                        {
                            <span class="login-title">Merhaba,</span>
                            <span class="login-name">Giriş Yap</span>
                        }
                        else
                        {
                            <span class="login-title">Hoş geldin,</span>
                            <span class="login-name">@kAdi</span>
                        }
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end">
                        @if (string.IsNullOrEmpty(kAdi))
                        {
                            <li><a class="dropdown-item" href="/Account/Login"><i class="fa-solid fa-right-to-bracket"></i> Üye Girişi</a></li>
                            <li><a class="dropdown-item" href="/Account/Register"><i class="fa-solid fa-user-plus"></i> Üye Ol</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item small text-muted" href="/Account/AdminLogin"><i class="fa fa-lock"></i> Yönetici Girişi</a></li>
                        }
                        else
                        {
                            <li><a class="dropdown-item" href="/Account/Hesabim"><i class="fa-regular fa-user"></i> Hesabım</a></li>
                            <li><a class="dropdown-item" href="/Account/Siparislerim"><i class="fa-solid fa-box-open"></i> Siparişlerim</a></li>
                            <li><a class="dropdown-item" href="/Account/Favorilerim"><i class="fa-regular fa-heart"></i> Favorilerim</a></li>
                            <li><a class="dropdown-item" href="/Account/Yorumlarim"><i class="fa-regular fa-comment-dots"></i> Yorumlarım</a></li>
                            <li><a class="dropdown-item" href="/Dolap/Index"><i class="fa-solid fa-shirt"></i> Dolabım</a></li>
                            <li><a class="dropdown-item" href="/Kombin/Index"><i class="fa-solid fa-wand-magic-sparkles"></i> Kombinlerim</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="fa-solid fa-power-off"></i> Çıkış Yap</a></li>
                        }
                    </ul>
                </div>

                <a href="/Sepet/Index" class="cart-container">
                    <i class="fa fa-shopping-basket fa-lg"></i>
                    <span>Sepetim</span>
                    @if (sepetAdet > 0)
                    {
                        <span class="cart-badge">@sepetAdet</span>
                    }
                </a>
            </div>
        </div>
    </div>

    <div class="purple-nav">
        <div class="container-fluid d-flex justify-content-between px-2 px-md-5">
            <div class="d-flex">
                <a href="/Home/Index" class="nav-link-custom">ANASAYFA</a>
                <a href="/Urun/TumUrunler" class="nav-link-custom">TÜM ÜRÜNLER</a>
                <a href="/Kategori/TumKategoriler" class="nav-link-custom">KATEGORİLER</a>
            </div>
            <div class="d-flex">
                <a href="/Urun/TumUrunler?siralama=en_yeniler" class="nav-link-custom">EN YENİLER</a>
                <a href="/Urun/TumUrunler?siralama=cok_satanlar" class="nav-link-custom" style="border:none;">ÇOK SATANLAR</a>
            </div>
        </div>
    </div>

    <div class="container-fluid px-0 mt-4 mb-5" style="min-height: 500px;">
        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>