@* =================================================================================================================
 * DOSYA ADI: Kategoriler.cshtml (Admin Kategori Yönetimi)
 * AMACI: Mağaza hiyerarşisinin temelini oluşturan ürün kategorilerinin eklenmesi, listelenmesi, 
 * güncellenmesi ve silinmesi işlemlerini merkezi bir panel üzerinden yönetir.
 * * KULLANILAN TEKNOLOJİLER VE KÜTÜPHANELER:
 * - Razor View Engine: 'List<Kategoriler>' modeli üzerinden veritabanı kayıtlarının tabloya dökülmesi.
 * - JavaScript (DOM Manipulation): Aynı modal yapısını hem 'Ekle' hem de 'Düzenle' işlemi için 
 * dinamik olarak dönüştüren (formSifirla / kategoriDoldur) fonksiyonel yapı.
 * - Bootstrap 5: Modal bileşeni, duyarlı tablo yapısı ve koyu tema (Dark Mode) uyumlu görsel elementler.
 * - Font-Awesome 6: İşlem butonları ve başlıklar için kullanılan kategorik ikon setleri.
 * * TASARIM VE FONKSİYONEL DETAYLAR:
 * 1. Hibrit Modal Kullanımı: JavaScript aracılığıyla formun 'action' adresi ve buton renkleri değiştirilerek 
 * tek bir modal üzerinden iki farklı işlem (Insert/Update) gerçekleştirilir.
 * 2. Güvenlik ve Veri Bütünlüğü: Silme işlemi öncesinde 'confirm' ile kullanıcıya ürünlerin de silineceğine 
 * dair kritik bir uyarı (Cascade Delete uyarısı) gösterilir.
 * 3. Görsel Standartlar: Koyu arka plan üzerinde neon pembe (#FF1493) vurgularla yönetici dikkati 
 * operasyonel alanlara çekilmiştir.
 * 4. UX Optimizasyonu: Düzenleme modunda 'focus' özelliği ile imlecin otomatik olarak kategori adı alanına 
 * odaklanması sağlanarak işlem hızı artırılmıştır.
 * 5. Layout Entegrasyonu: 'AdminLayout.cshtml' kullanılarak tüm yönetim panelinde navigasyon bütünlüğü korunmuştur.
 ================================================================================================================= *@

@model List<ClothingStore.Models.Kategoriler>
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <div class="bg-turuncu p-2 rounded me-3 shadow">
                <i class="fa fa-tags text-white fs-4"></i>
            </div>
            <h2 class="text-white fw-bold mb-0">Kategori Yönetimi</h2>
        </div>
        <button class="btn btn-warning fw-bold shadow px-4 text-white" data-bs-toggle="modal" data-bs-target="#kategoriIslemModal" onclick="formSifirla()">
            <i class="fa fa-plus-circle me-2"></i>Yeni Kategori Ekle
        </button>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card bg-dark border-secondary shadow-lg overflow-hidden">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle mb-0">
                            <thead class="text-turuncu border-bottom border-turuncu">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 100px;">ID</th>
                                    <th class="py-3">Kategori Adı</th>
                                    <th class="text-end pe-4 py-3">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="border-bottom border-secondary">
                                        <td class="ps-4 text-white-50 small">#@item.KategoriId</td>
                                        <td class="text-white fw-bold">@item.KategoriAdi</td>
                                        <td class="text-end pe-4">
                                            <button class="btn btn-sm btn-outline-warning border-0 me-2"
                                                    data-bs-toggle="modal" data-bs-target="#kategoriIslemModal"
                                                    onclick="kategoriDoldur('@item.KategoriId', '@item.KategoriAdi')">
                                                <i class="fa fa-edit fs-5"></i>
                                            </button>
                                            <a href="/Admin/KategoriSil/@item.KategoriId"
                                               class="btn btn-sm btn-outline-danger border-0"
                                               onclick="return confirm('DİKKAT: @item.KategoriAdi kategorisini silerseniz, içindeki TÜM ÜRÜNLER de kalıcı olarak silinecektir! Yine de onaylıyor musunuz?')">
                                                <i class="fa fa-trash fs-5"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="kategoriIslemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-turuncu shadow-lg overflow-hidden">
            <div class="modal-header bg-turuncu border-0 rounded-0">
                <h5 class="modal-title fw-bold text-white mb-0" id="formBaslik">
                    <i class="fa fa-plus-circle me-2"></i>Yeni Kategori Ekle
                </h5>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="kategoriForm" action="/Admin/KategoriEkle" method="post">
                    <input type="hidden" name="KategoriId" id="txtKategoriId" value="" />

                    <div class="mb-4">
                        <label class="text-turuncu small fw-bold mb-2 d-block">KATEGORİ ADI</label>
                        <input type="text" name="KategoriAdi" id="txtKategoriAdi"
                               class="form-control bg-secondary text-white border-0 py-2 shadow-none"
                               placeholder="Örn: Elbise" required />
                    </div>

                    <div class="d-grid">
                        <button type="submit" id="btnKaydet" class="btn btn-warning fw-bold py-2 shadow-sm text-white">
                            KAYDET
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function kategoriDoldur(id, ad) {
        document.getElementById('txtKategoriId').value = id;
        document.getElementById('txtKategoriAdi').value = ad;

        document.getElementById('formBaslik').innerHTML = '<i class="fa fa-edit me-2"></i>Kategoriyi Düzenle';
        document.getElementById('btnKaydet').innerText = "GÜNCELLEMELERİ KAYDET";
        document.getElementById('btnKaydet').className = "btn btn-info fw-bold py-2 shadow text-white";
        document.getElementById('kategoriForm').action = "/Admin/KategoriGuncelle";

        setTimeout(() => document.getElementById('txtKategoriAdi').focus(), 500);
    }

    function formSifirla() {
        document.getElementById('txtKategoriId').value = "";
        document.getElementById('txtKategoriAdi').value = "";
        document.getElementById('formBaslik').innerHTML = '<i class="fa fa-plus-circle me-2"></i>Yeni Kategori Ekle';
        document.getElementById('btnKaydet').innerText = "KAYDET";
        document.getElementById('btnKaydet').className = "btn btn-warning fw-bold py-2 shadow text-white";
        document.getElementById('kategoriForm').action = "/Admin/KategoriEkle";
    }
</script>

<style>
    .bg-turuncu {
        background-color: #FF1493 !important;
    }

    .bg-turuncu-koyu {
        background-color: #FF1493;
    }

    .border-turuncu {
        border: 1px solid #FF1493 !important;
    }

    .text-turuncu {
        color: #FF1493 !important;
    }

    .btn-warning {
        background-color: #FF1493;
        border: none;
    }

        .btn-warning:hover {
            background-color: #FF1493;
        }

    .btn-info {
        background-color: #0dcaf0;
        border: none;
    }

    .form-control:focus {
        background-color: #444 !important;
        color: white;
        box-shadow: none;
        border: 1px solid #FF1493;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255, 96, 0, 0.05) !important;
    }

    .modal-content {
        border-radius: 8px;
    }
</style>